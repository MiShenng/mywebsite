{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Hugo: Start Dev Server",
      "type": "shell",
      "command": "hugo server --buildDrafts --disableFastRender",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(ERROR.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Running in Fast Render Mode.*$",
          "endsPattern": "^.*Web Server is available at.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "hugo"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
